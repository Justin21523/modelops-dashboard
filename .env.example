# Copy to .env and adjust for your local environment.
# Do NOT commit a real .env file or real secrets.

# Active Spring profile
SPRING_PROFILES_ACTIVE=dev

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=modelops
DB_USERNAME=modelops
DB_PASSWORD=modelops

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Application
SERVER_PORT=8080

# JWT (Base64-encoded HS256 secret). Generate your own, e.g.:
#   openssl rand -base64 48
APP_SECURITY_JWT_SECRET=ZGV2LW9ubHktc2VjcmV0LWNoYW5nZS1tZS1pbi1wcm9kdWN0aW9uLTEyMzQ1Njc4OTA=
APP_SECURITY_JWT_EXPIRATION=PT1H
APP_SECURITY_JWT_REFRESH_EXPIRATION=P30D
